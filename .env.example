# ── Firebase ───────────────────────────────────────────────────
# Rename this file to .env.local and fill in your values.
# These are exposed to the browser (safe for Firebase client SDK).

NEXT_PUBLIC_FIREBASE_API_KEY=REPLACE_apiKey
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=REPLACE_authDomain
NEXT_PUBLIC_FIREBASE_DATABASE_URL=REPLACE_databaseURL
NEXT_PUBLIC_FIREBASE_PROJECT_ID=REPLACE_projectId
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=REPLACE_storageBucket
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=REPLACE_messagingSenderId
NEXT_PUBLIC_FIREBASE_APP_ID=REPLACE_appId
NEXT_PUBLIC_VAPID_KEY=REPLACE_vapidKey
